DATABASE_URL="postgresql://postgres:password@localhost:5432/neon_alpha_terminal?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
PORT=5000
NODE_ENV=development
COINGECKO_API_KEY=""

# Telegram Bot Configuration
# 1. Message @BotFather on Telegram to create a bot
# 2. Copy the bot token here
# 3. Create a channel/group and add the bot as admin
# 4. Send a message in the channel, then visit:
#    https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# 5. Find the chat.id value and paste it here
TELEGRAM_BOT_TOKEN="your-bot-token-from-botfather"
TELEGRAM_CHAT_ID="your-channel-chat-id"

# Stripe Configuration
# 1. Sign up at https://stripe.com
# 2. Get your secret key from Dashboard > Developers > API keys
# 3. Create products and prices in Dashboard > Products
# 4. Get Price IDs for Basic (£9.99/month) and Pro (£19.99/month) plans
# 5. Get webhook secret from Dashboard > Developers > Webhooks
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_BASIC_PRICE_ID="price_..."      # £9.99/month subscription
STRIPE_PRO_PRICE_ID="price_..."        # £19.99/month subscription
STRIPE_LIFETIME_PRICE_ID="price_..."   # £199 one-time payment
FRONTEND_URL="http://localhost:3000"
